rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if (resource.data.isDraft != true && resource.data.isDraft != "true") || (request.auth != null && request.auth.token.email == 'dr-mohammed-shabaan@dr.com');
      allow write: if request.auth != null && request.auth.token.email == 'dr-mohammed-shabaan@dr.com';
    }
  }
}
